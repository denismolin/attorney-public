# ============================================================================
# Configuration de l'assistant juridique RAG — Succession
# Copier ce fichier en `.env` et renseigner les valeurs.
# Le `.env` n'est JAMAIS commité (cf .gitignore).
# ============================================================================

# --- Choix des providers (au lancement) ---------------------------------------
# EMBED_PROVIDER : openai | mistral | vllm   (PAS anthropic — pas d'API embeddings)
# CHAT_PROVIDER  : openai | anthropic | mistral | vllm
EMBED_PROVIDER=openai
CHAT_PROVIDER=openai

# --- Modèles ------------------------------------------------------------------
EMBED_MODEL=text-embedding-3-large
CHAT_MODEL=gpt-4o
# Exemples par provider :
#   openai    -> EMBED_MODEL=text-embedding-3-large  CHAT_MODEL=gpt-4o
#   mistral   -> EMBED_MODEL=mistral-embed           CHAT_MODEL=mistral-large-latest
#   anthropic ->                                     CHAT_MODEL=claude-opus-4-8  (chat only)
#   vllm      -> EMBED_MODEL=<ton-modele-embed>      CHAT_MODEL=auto
# Astuce vLLM : CHAT_MODEL=auto -> l'app détecte le modèle instruct déployé via
# /models et s'adapte automatiquement si tu le changes côté serveur.

# --- Clés API (selon providers choisis) ---------------------------------------
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
MISTRAL_API_KEY=

# --- vLLM (service HTTPS perso, API OpenAI-compatible) ------------------------
VLLM_BASE_URL=https://your-vllm-host/v1
VLLM_API_KEY=

# --- ChromaDB (service Docker séparé) -----------------------------------------
# En dev local : localhost. Dans le compose : chromadb (nom du service).
CHROMA_HOST=localhost
CHROMA_PORT=8000

# --- Flask --------------------------------------------------------------------
FLASK_HOST=0.0.0.0
FLASK_PORT=5000

# --- Indexation ---------------------------------------------------------------
# Taille cible des chunks (caractères approx.) et recouvrement.
CHUNK_SIZE=3500
CHUNK_OVERLAP=400
